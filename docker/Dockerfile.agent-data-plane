# syntax=docker/dockerfile:1.24
# This Dockerfile is, generally speaking, tuned for CI builds.
#
# It is designed to work seamlessly in both local builds and CI environments, but as CI is invoked far more often,
# we naturally prefer to optimize for CI usage. To this end, one common pattern we utilize in this Dockerfile is "clean"
# vs "prepped" build layers.
#
# Simply put, for parts of the build where we might end up doing a lot of work that could otherwise be pre-computed,
# we'll declare a "clean" and "prepped" version of that layer, where the "clean" layer includes all of the necessary steps
# to do whatever it needs to do -- install packages, and so on -- while the "prepped" layer is basically just a pass-through
# to an image that was built outside of this Dockerfile.

ARG BUILDCACHE_IMAGE=scratch
ARG SPDX_LICENSES_IMAGE=scratch
ARG BUILD_IMAGE=ubuntu:24.04
ARG BUILD_BASE=build-clean
ARG APP_IMAGE=ubuntu:24.04

# Buildcache stage: declare the buildcache "source" image so we can refer to it later on.
FROM ${BUILDCACHE_IMAGE} AS buildcache-src

# SPDX licenses stage: declare the optional prebuilt SPDX license "source" image, consumed by the
# final-prep stage. Defaults to `scratch`; when left as the default, the license harvest fetches the
# SPDX texts from GitHub instead of reading them from this image.
FROM ${SPDX_LICENSES_IMAGE} AS spdx-licenses-src

# Build stage: base layer preparation.
FROM ${BUILD_IMAGE} AS build-clean
ENV PATH="/root/.cargo/bin:${PATH}"

RUN --mount=type=bind,source=docker/scripts,target=/scripts \
    --mount=type=bind,source=rust-toolchain.toml,target=/tmp/rust-toolchain.toml \
    sh /scripts/run-stage.sh agent-data-plane build-prep

FROM ${BUILD_IMAGE} AS build-prepped
ENV PATH="/root/.cargo/bin:${PATH}"

# Build stage: build Agent Data Plane.
FROM ${BUILD_BASE} AS adp-builder

ARG TARGETARCH
ARG RUST_VERSION=stable
ARG BUILD_PROFILE=release
ARG BUILD_FEATURES=default
ARG BUILD_TARGET
ARG BUILD_CFLAGS=""
# When "true", wrap the cargo build with `cargo auditable` so the binary embeds an SBOM (dependency
# tree). CI sets this for published/internal builds; local `make build-adp-image` leaves it false.
ARG USE_CARGO_AUDITABLE=false
ARG APP_FULL_NAME=""
ARG APP_SHORT_NAME=""
ARG APP_IDENTIFIER=""
ARG APP_GIT_HASH=""
ARG APP_VERSION=""
ARG APP_BUILD_TIME=""
ARG INTERNAL_BUILD=""
ARG BUILDCACHE_REMOTE=
ARG BUILDCACHE_DEBUG=

# Application metadata embedded into the binary by the build.
ENV APP_FULL_NAME=${APP_FULL_NAME}
ENV APP_SHORT_NAME=${APP_SHORT_NAME}
ENV APP_IDENTIFIER=${APP_IDENTIFIER}
ENV APP_GIT_HASH=${APP_GIT_HASH}
ENV APP_VERSION=${APP_VERSION}
ENV APP_BUILD_TIME=${APP_BUILD_TIME}
ENV BUILDCACHE_REMOTE=${BUILDCACHE_REMOTE}
ENV BUILDCACHE_DEBUG=${BUILDCACHE_DEBUG}

# Build parameters consumed by the actual build commands.
ENV BUILD_TARGET=${BUILD_TARGET}
ENV BUILD_PROFILE=${BUILD_PROFILE}
ENV BUILD_FEATURES=${BUILD_FEATURES}
ENV BUILD_CFLAGS=${BUILD_CFLAGS}
ENV USE_CARGO_AUDITABLE=${USE_CARGO_AUDITABLE}

# Build Agent Data Plane.
WORKDIR /adp
COPY . /adp

# We mount a number of caches that should also for shared/incremental Cargo builds across separate _Docker_ builds,
# so long as the build target/profile are the same.
#
# When the source (COPY . /adp) layer changes, this will invalidate this layer but it won't invalidate the caches
# themselves, which should still allow for reusing previously cached build artifacts, if they exist.
RUN --mount=type=bind,source=docker/scripts,target=/scripts \
    --mount=type=bind,from=buildcache-src,source=/,target=/mnt/bcsrc \
    --mount=type=secret,id=aws-creds,target=/run/secrets/aws-creds.sh,required=false \
    --mount=type=cache,target=/adp/target,id=adp-target-${BUILD_TARGET}-${BUILD_PROFILE} \
    --mount=type=cache,target=/root/.cargo/registry,id=cargo-registry \
    --mount=type=cache,target=/root/.cargo/git,id=cargo-git \
    sh /scripts/run-stage.sh agent-data-plane build

# Final preparation stage: assemble everything the final image needs into a mirrored directory tree under `/rootfs`.
#
# Each artifact lands at the path it will occupy in the running image, so the `final` stage can drop the whole tree in
# with a single COPY. This serves as a layer for adding in additional outputs, such as license files, profiling helpers,
# and so on.
FROM ${BUILD_IMAGE} AS final-prep

ARG TARGETARCH
ARG INTERNAL_BUILD=""
ARG SPDX_LICENSES_VERSION=3.28.0
ENV BUILD_ROOT=/rootfs
ENV TARGETARCH=${TARGETARCH}
ENV INTERNAL_BUILD=${INTERNAL_BUILD}
ENV SPDX_LICENSES_VERSION=${SPDX_LICENSES_VERSION}

RUN --mount=type=bind,source=docker/scripts,target=/scripts \
    --mount=type=bind,source=ci/tooling,target=/tooling \
    --mount=type=bind,source=LICENSE-3rdparty.csv,target=/tmp/LICENSE-3rdparty.csv \
    --mount=type=bind,from=spdx-licenses-src,source=/,target=/mnt/spdx \
    sh /scripts/run-stage.sh agent-data-plane final-prep

# Copy over a number of static outputs from either the build context or the build stage. We do these last as they're the
# most likely to change across builds, and we want to maximize caching for all of the pre-built layers above.
COPY NOTICE LICENSE LICENSE-3rdparty.csv /rootfs/opt/datadog/agent-data-plane/
COPY --chmod=755 docker/entrypoint.sh /rootfs/entrypoint.sh
COPY --from=adp-builder /out/agent-data-plane /rootfs/usr/local/bin/agent-data-plane

# Final stage: lay the assembled tree on top of the configured application base image.
FROM ${APP_IMAGE} AS final

# We don't want to set the user to `root` in the application image, but `apt-get` needs it -- so we switch to `root`
# and let 00-install-ca-certs.sh decide whether an install is actually necessary (it's a no-op when CA certificates
# are already present, as they are in CI base images).
USER root
RUN --mount=type=bind,source=docker/scripts,target=/scripts \
    sh /scripts/run-stage.sh agent-data-plane app

# Everything else was assembled into the mirrored tree, so a single copy drops it all into place.
COPY --from=final-prep /rootfs/ /

ENTRYPOINT [ "/usr/local/bin/agent-data-plane" ]
