SCENARIO_TEST_NAME="saluki-adp-differential"
SCENARIO_DESCRIPTION="ADP differential: Datadog Agent ADP-on vs Datadog Agent ADP-off"
# No node faults. Terminating, hanging, or throttling can't be done as a group
# so there's no fair way to fault the lanes.
SCENARIO_FAULT_NODES=""
# Exclude every container from network faults. The count oracle compares per-context
# point multiplicity across the lanes, and a cumulative count cannot self-heal: an
# asymmetric partition on a SUT->intake link drops points on one lane only and skews
# the count forever. Excluding intake alone is not enough -- a network partition
# isolates a non-excluded container, so partitioning datadog-agent still severs its
# link to the exempt intake and starves the agent lane's capture (run
# 5988e4ed172922f5582cb9d413bf576a-58-7 red'd exactly this way). Naming all four
# containers leaves no faultable network link in the scenario. cpu_mod and
# clock_jitter stay on, both global and symmetric.
SCENARIO_EXCLUDE_FROM_NETWORK_FAULTS="intake workload datadog-agent adp"
